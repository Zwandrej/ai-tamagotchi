{
  "name": "ai-tamagotchi",
  "version": "0.1.0",
  "description": "AI-powered digital pet that lives on your home screen. Cross-platform, fully on-device, open source.",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "react-native start",
    "ios": "react-native run-ios",
    "android": "react-native run-android",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "benchmark": "ts-node scripts/benchmark.ts"
  },
  "dependencies": {
    "@react-native/codegen": "^0.85.3",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "llama.rn": "^0.12.4",
    "react": "19.1.1",
    "react-native": "^0.82.1",
    "react-native-fs": "^2.20.0",
    "react-native-mmkv": "^3.1.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native/metro-config": "^0.85.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.12",
    "@types/react-native": "^0.73.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|tsx)$",
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/constants/creatures.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  }
}
